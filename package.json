{
  "name": "zalo-desktop",
  "version": "1.0.0",
  "description": "Ubuntu-focused Electron desktop wrapper for Zalo Web.",
  "main": "out/main/index.js",
  "desktopName": "com.zalo.desktop.desktop",
  "author": "Zalo Desktop Community",
  "license": "MIT",
  "homepage": "https://chat.zalo.me",
  "private": true,
  "scripts": {
    "clean": "rimraf out dist",
    "compile": "tsc -p tsconfig.json",
    "dev": "npm run compile && electron .",
    "build": "npm run compile && electron-builder",
    "build:dir": "npm run compile && electron-builder --dir"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "electron": "42.5.0",
    "electron-builder": "26.15.3",
    "rimraf": "6.1.3",
    "typescript": "6.0.3"
  }
}
